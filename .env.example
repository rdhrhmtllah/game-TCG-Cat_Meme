# ============================================================
# .env.example — MemeCats Environment Variables Template
# Copy isi file ini ke .env saat development, dan ke
# Environment Variables di Vercel Dashboard saat deploy.
# ============================================================

# --- GENERATE SENDIRI (random string, min. 32 karakter) ---
JWT_SECRET=CHANGE_ME
ADMIN_SECRET=CHANGE_ME
CRON_SECRET=CHANGE_ME

# --- PERLU DIISI MANUAL ---
DATABASE_URL=CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
BLOB_READ_WRITE_TOKEN=CHANGE_ME

# --- CLOUDFLARE TURNSTILE (anti-bot login/register/admin) ---
# Buat widget di dash.cloudflare.com > Turnstile. Kosongkan = fitur off (dilewati).
# Secret key (backend, RAHASIA):
TURNSTILE_SECRET_KEY=
# Site key (frontend, publik) — HARUS diprefiks VITE_ agar terbaca saat build:
VITE_TURNSTILE_SITE_KEY=

# --- STATIS ---
NODE_ENV=development
